<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Certificate</title>
  <style>
    body { font-family: 'Helvetica', sans-serif; text-align: center; }
    .certificate { border: 10px solid #333; padding: 40px; }
    h1 { font-size: 32px; margin-bottom: 20px; }
    .details { font-size: 18px; margin-top: 20px; }
    .footer { margin-top: 40px; font-size: 14px; }
  </style>
</head>
<body>
  <div class="certificate">
    <h1>Certificate of Completion</h1>
    <p>This certifies that</p>
    <h2>{{name}}</h2>
    <p class="details">has successfully completed the course</p>
    <h3>{{courseTitle}}</h3>
    {{#if grade}}
      <p>with grade: {{grade}}</p>
    {{/if}}
    <div class="footer">
      <p>Date: {{date}}</p>
      <img src="{{signatureUrl}}" alt="Signature" height="50"/>
    </div>
  </div>
</body>
</html>
